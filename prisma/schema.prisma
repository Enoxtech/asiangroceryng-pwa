// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id               String   @id
  name             String
  slug             String   @unique
  description      String
  shortDescription String
  price            Float
  comparePrice     Float?
  images           String[]
  category         String
  categorySlug     String
  brand            String
  countryOfOrigin  String
  countryFlag      String
  weight           String
  ingredients      String?
  allergens        String?
  expiryInfo       String?
  storageType      String
  spiceLevel       String?
  inStock          Boolean  @default(true)
  stockCount       Int      @default(0)
  isFeatured       Boolean  @default(false)
  isNew            Boolean  @default(false)
  isOnSale         Boolean  @default(false)
  discount         Int?
  tags             String[]
  rating           Float    @default(0)
  reviewCount      Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Category {
  id           String @id
  name         String
  slug         String @unique
  image        String
  description  String
  productCount Int    @default(0)
  emoji        String
}

model Order {
  id                String           @id
  customer          String
  phone             String
  email             String?
  subtotal          Float
  deliveryFee       Float
  discount          Float            @default(0)
  tax               Float            @default(0)
  couponCode        String?
  total             Float
  status            String           @default("pending")
  area              String
  address           String?
  payment           String
  paymentRef        String?
  paymentStatus     PaymentStatus    @default(pending)
  paymentProvider   String?
  paidAt            DateTime?
  paymentExpiresAt  DateTime?
  paymentNotifiedAt DateTime?
  notes             String?
  source            String           @default("checkout")
  createdAt         DateTime         @default(now())
  items             OrderItem[]
  customerId        String?
  customerAccount   Customer?        @relation(fields: [customerId], references: [id])
  paymentAttempts   PaymentAttempt[]

  @@index([customerId])
}

enum PaymentStatus {
  pending
  paid
  failed
  expired
  refunded
}

model PaymentAttempt {
  id                    String        @id @default(cuid())
  orderId               String
  order                 Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider              String
  reference             String        @unique
  amountKobo            Int
  currency              String        @default("NGN")
  status                PaymentStatus @default(pending)
  accountNumber         String?
  accountName           String?
  bankName              String?
  expiresAt             DateTime?
  paidAt                DateTime?
  providerTransactionId String?
  lastCheckedAt         DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([orderId])
  @@index([status, expiresAt])
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name         String
  quantity     Int
  price        Float
  productId    String?
  categorySlug String?
}

model Banner {
  id         String  @id
  image      String
  headline   String
  subtitle   String
  ctaLabel   String
  ctaHref    String
  transition String
  align      String
  enabled    Boolean @default(true)
  position   Int     @default(0)
}

model BankDetails {
  id            String @id @default("singleton")
  bankName      String @default("")
  accountNumber String @default("")
  accountName   String @default("")
  bankBranch    String @default("")
  note          String @default("")
}

enum AdminRole {
  super_admin
  support
  product_manager
}

model AdminUser {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  passwordHash        String
  role                AdminRole
  active              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  lastLoginAt         DateTime?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  sessionVersion      Int       @default(0)
  totpSecret          String?
  totpEnabled         Boolean   @default(false)
}

model Customer {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  passwordHash        String
  phone               String
  address             String?
  emailVerified       Boolean   @default(false)
  verifyToken         String?   @unique
  verifyTokenExpires  DateTime?
  resetToken          String?   @unique
  resetTokenExpires   DateTime?
  sessionVersion      Int       @default(0)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())
  lastLoginAt         DateTime?
  orders              Order[]
}

model IntegrationSettings {
  id                        String @id @default("singleton")
  paystackPublicKey         String @default("")
  paystackSecretKey         String @default("")
  flutterwavePublicKey      String @default("")
  flutterwaveSecretKey      String @default("")
  gmailUser                 String @default("")
  gmailAppPassword          String @default("")
  adminEmail                String @default("")
  resendApiKey              String @default("")
  resendFromEmail           String @default("")
  vatPercent                Float  @default(0)
  whatsappPhoneNumberId     String @default("")
  whatsappAccessToken       String @default("")
  whatsappBusinessAccountId String @default("")
  whatsappOrderTemplateName String @default("")
  whatsappTemplateLanguage  String @default("en_US")
  storeName                 String @default("Asian Grocery Nigeria")
  tagline                   String @default("Exploring Asia Through Food")
  storeEmail                String @default("hello@asiangroceryng.com")
  storeAddress              String @default("Lagos, Nigeria")
  deliveryFreeThreshold     Float  @default(15000)
  businessHoursWeekdays     String @default("8:00 AM – 7:00 PM WAT")
  businessHoursSaturday     String @default("9:00 AM – 5:00 PM WAT")
  businessHoursSunday       String @default("Closed")
}

model DeliveryArea {
  id            String  @id @default(cuid())
  name          String
  fee           Float
  estimatedDays String
  enabled       Boolean @default(true)
  position      Int     @default(0)
}

model Coupon {
  id         String    @id @default(cuid())
  code       String    @unique
  type       String
  value      Float
  minOrder   Float?
  active     Boolean   @default(true)
  expiresAt  DateTime?
  usageLimit Int?
  usageCount Int       @default(0)
  createdAt  DateTime  @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  adminEmail String
  adminName  String
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([adminId])
}

model RateLimitHit {
  id        String   @id @default(cuid())
  key       String
  createdAt DateTime @default(now())

  @@index([key, createdAt])
}
